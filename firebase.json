{
  "hosting": {
    "site": "qr-smart-attendance",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".*",
      ".*/**",
      "**/.*",
      "**/.*/**",
      ".git/**",
      ".agents/**",
      ".codex/**",
      "**/node_modules/**",
      "attendify-support-chatbot/**"
    ],
    "redirects": [
      {
        "source": "/coming-soon.html",
        "destination": "/index.html",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
