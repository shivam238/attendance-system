# GEMINI_API_KEY: Required — primary AI provider (Google Gemini 2.5 Flash)
# Get from: https://aistudio.google.com/app/apikey
# Set in Netlify: Site Settings → Environment Variables
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENROUTER_API_KEY: Optional — fallback AI provider (OpenRouter)
# Automatically used when Gemini fails, hits a rate limit, or quota is exceeded.
# Free tier available. Get from: https://openrouter.ai/keys
# Set in Netlify: Site Settings → Environment Variables
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
