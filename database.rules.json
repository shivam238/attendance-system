{
  "rules": {
    "users": {
      ".read": true,
      ".indexOn": ["username"],
      "$uid": {
        ".write": "$uid === auth.uid"
      }
    },
    "attendance": {
      ".read": true,
      ".write": true,
      "$session_id": {
         ".indexOn": ["rollNo"]
      }
    },
    "requests": {
      ".read": true,
      ".write": true
    },
    "qr_sessions": {
      ".read": true,
      ".write": true
    }
  }
}